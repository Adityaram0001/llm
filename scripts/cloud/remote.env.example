# Copy to remote.env (gitignored) and fill in from the provider console after renting a pod.
REMOTE_USER=root
REMOTE_HOST=1.2.3.4          # or ssh proxy hostname from the console
REMOTE_PORT=22               # RunPod usually gives a non-standard port
REMOTE_DIR=/workspace/llm-lab
SSH_KEY=~/.ssh/id_ed25519
