# Copy to .env (gitignored — never commit, repo is public) and fill in real values.
# These configure rclone's "r2:" remote via env vars, no `rclone config` wizard needed —
# the same var names also drive the pod-template side of the Docker fast-start (docs/CLOUD.md).
#
# Where to get these (Cloudflare dashboard → R2):
#   RCLONE_CONFIG_R2_ENDPOINT       R2 → bucket "llmlab" → Settings → copy the "S3 API" endpoint
#                                   (https://<account-id>.r2.cloudflarestorage.com)
#   RCLONE_CONFIG_R2_ACCESS_KEY_ID  R2 → Manage API Tokens → Create API Token
#   RCLONE_CONFIG_R2_SECRET_ACCESS_KEY   (shown once at token creation — save it now)
#   Scope the token to "Object Read & Write" on the bucket only (not account-wide).
RCLONE_CONFIG_R2_TYPE=s3
RCLONE_CONFIG_R2_PROVIDER=Cloudflare
RCLONE_CONFIG_R2_ACCESS_KEY_ID=
RCLONE_CONFIG_R2_SECRET_ACCESS_KEY=
RCLONE_CONFIG_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

R2_BUCKET=llm

# wandb — dashboard for live/offline run comparison, see docs/WANDB.md
#   WANDB_API_KEY   wandb.ai -> Settings -> API keys
#   WANDB_ENTITY    your wandb username or team (the account the runs sync under)
# Project name is NOT set here — it's config-driven (TrainConfig.wandb_project, default
# "llm-lab", D-005) so it can't drift between runs. Set logging.wandb_mode: online in a
# config, or pass `--wandb-online` to scripts/train.py, to stream a run live instead of
# writing offline-only (D-009's default).
WANDB_API_KEY=
WANDB_ENTITY=

# DeepSeek data-factory API backend (phase 7, D-048). Get a key at platform.deepseek.com.
# Use deepseek-chat (the cheaper V3-class model); context caching is automatic server-side.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
